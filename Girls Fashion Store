<div class="sidebar">
<h3>Category</h3>
<label><input type="radio" name="category" value="all" checked> All</label>
<label><input type="radio" name="category" value="jacket"> Jackets</label>
<label><input type="radio" name="category" value="heels"> Heels</label>
<label><input type="radio" name="category" value="bag"> Handbags</label>
<label><input type="radio" name="category" value="accessories"> Accessories</label>

<h3 style="margin-top:15px;">Price</h3>
<input type="range" id="priceRange" min="500" max="3000" value="3000">
<p>Max Price: ₹<span id="priceValue">3000</span></p>
</div>

<!-- PRODUCTS -->
<div class="products" id="productList">

<div class="product" data-category="jacket" data-price="1999">
<img src="https://images.pexels.com/photos/934070/pexels-photo-934070.jpeg">
