</div>

<div class="product" data-category="bag" data-price="1299">
<img src="https://images.pexels.com/photos/1152077/pexels-photo-1152077.jpeg">
<h4>Stylish Handbag</h4>
<p>₹1299</p>
</div>

<div class="product" data-category="accessories" data-price="599">
<img src="https://images.pexels.com/photos/1927259/pexels-photo-1927259.jpeg">
<h4>Jewelry Set</h4>
<p>₹599</p>
</div>

<div class="product" data-category="heels" data-price="2200">
<img src="https://images.pexels.com/photos/19090/pexels-photo.jpg">
<h4>Designer Heels</h4>
<p>₹2200</p>
</div>

<div class="product" data-category="jacket" data-price="2500">
<img src="https://images.pexels.com/photos/994523/pexels-photo-994523.jpeg">
<h4>Leather Jacket</h4>
<p>₹2500</p>
</div>

</div>

</div>

<!-- FOOTER -->
