<body>

<!-- NAVBAR -->
<div class="navbar">
<h2>Girls Store</h2>
<ul>
<li><a href="index.html">Home</a></li>
<li><a href="shop.html">Shop</a></li>
<li><a href="cart.html">Cart</a></li>
</ul>
</div>

<!-- CART -->
<div class="cart-container">

<!-- ITEM 1 -->
<div class="cart-item" data-price="1999">
<img src="https://images.pexels.com/photos/934070/pexels-photo-934070.jpeg">
<div class="cart-details">
<h4>Winter Jacket</h4>
<p class="price">₹1999</p>
</div>

<div class="quantity">
<button onclick="changeQty(this,-1)">-</button>
<span class="qty">1</span>
<button onclick="changeQty(this,1)">+</button>
</div>

<div class="item-total">₹1999</div>
</div>

<!-- ITEM 2 -->
<div class="cart-item" data-price="1499">
<img src="https://images.pexels.com/photos/336372/pexels-photo-336372.jpeg">
<div class="cart-details">
<h4>Party Heels</h4>
<p class="price">₹1499</p>
</div>

<div class="quantity">
<button onclick="changeQty(this,-1)">-</button>
<span class="qty">1</span>
<button onclick="changeQty(this,1)">+</button>
</div>

<div class="item-total">₹1499</div>
</div>

<!-- ITEM 3 -->
<div class="cart-item" data-price="1299">
<img src="https://images.pexels.com/photos/1152077/pexels-photo-1152077.jpeg">
<div class="cart-details">
<h4>Handbag</h4>
<p class="price">₹1299</p>
</div>

<div class="quantity">
<button onclick="changeQty(this,-1)">-</button>
<span class="qty">1</span>
<button onclick="changeQty(this,1)">+</button>
</div>

<div class="item-total">₹1299</div>
</div>

<!-- TOTAL -->
<div class="total-section">
<h2>Total: ₹<span id="grandTotal">4797</span></h2>
</div>

</div>

<!-- FOOTER -->
<div class="footer">
<p>© 2026 Girls Store | All Rights Reserved</p>
</div>

<!-- SCROLL -->
<button id="topBtn">↑</button>

<script>

// UPDATE TOTAL
function updateTotal(){
let total = 4797;
document.querySelectorAll(".cart-item").forEach(item=>{
let price = item.getAttribute("data-price");
let qty = item.querySelector(".qty").innerText;
let itemTotal = price * qty;
item.querySelector(".item-total").innerText = "₹" + itemTotal;
total += itemTotal;
});
document.getElementById("grandTotal").innerText = total;
}

// CHANGE QTY
function changeQty(btn, change){
let qtyElement = btn.parentElement.querySelector(".qty");
let qty = parseInt(qtyElement.innerText);

qty += change;
if(qty < 1) qty = 1;

qtyElement.innerText = qty;
updateTotal();
}

// INITIAL LOAD
updateTotal();

// SCROLL BUTTON
let btn = document.getElementById("topBtn");

window.onscroll = function(){
if(document.documentElement.scrollTop>200){
btn.style.display="block";
}else{
btn.style.display="none";
}
};

btn.onclick = function(){
window.scrollTo({top:0,behavior:"smooth"});
};

</script>

</body>
