<p>© 2026 Girls Store | All Rights Reserved</p>
</div>

<!-- SCROLL BUTTON -->
<button id="topBtn">↑</button>

<script>
// FILTER LOGIC
let radios = document.querySelectorAll("input[name='category']");
let products = document.querySelectorAll(".product");
let priceRange = document.getElementById("priceRange");
let priceValue = document.getElementById("priceValue");

function filterProducts(){
let selected = document.querySelector("input[name='category']:checked").value;
let maxPrice = priceRange.value;

products.forEach(p=>{
let cat = p.getAttribute("data-category");
let price = p.getAttribute("data-price");

if((selected=="all" || cat==selected) && price <= maxPrice){
p.style.display="block";
}else{
p.style.display="none";
}
});
}

// EVENT LISTENERS
radios.forEach(r=>r.addEventListener("change", filterProducts));
priceRange.addEventListener("input", ()=>{
priceValue.innerText = priceRange.value;
filterProducts();
});

// SCROLL BUTTON
let btn = document.getElementById("topBtn");

window.onscroll = function(){
if(document.documentElement.scrollTop>200){
btn.style.display="block";
}else{
btn.style.display="none";
}
};

btn.onclick = function(){
window.scrollTo({top:0,behavior:"smooth"});
};
</script>

</body>
